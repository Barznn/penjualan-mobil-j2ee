<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
   http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
   version="3.1">
    
    <display-name>Penjualan Mobil J2EE</display-name>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Servlet Mappings -->
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.penjualan.servlet.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.penjualan.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.penjualan.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.penjualan.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SearchMobilServlet</servlet-name>
        <servlet-class>com.penjualan.servlet.SearchMobilServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchMobilServlet</servlet-name>
        <url-pattern>/search</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DetailMobilServlet</servlet-name>
        <servlet-class>com.penjualan.servlet.DetailMobilServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DetailMobilServlet</servlet-name>
        <url-pattern>/detail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BuyMobilServlet</servlet-name>
        <servlet-class>com.penjualan.servlet.BuyMobilServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BuyMobilServlet</servlet-name>
        <url-pattern>/buy</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RiwayatPembelianServlet</servlet-name>
        <servlet-class>com.penjualan.servlet.RiwayatPembelianServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RiwayatPembelianServlet</servlet-name>
        <url-pattern>/riwayat</url-pattern>
    </servlet-mapping>

    <!-- Session Configuration -->
    <session-config>
        <tracking-mode>COOKIE</tracking-mode>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>
</web-app>
